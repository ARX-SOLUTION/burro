{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/token_usage.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Agent"
      },
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/post_pr_capture.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_tool_guard.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/session_context.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/user_prompt_router.py",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git fetch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr status)",
      "Bash(gh pr edit *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr checks *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push * --force *)",
      "Bash(git push * --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./node_modules/**)",
      "Read(./**/node_modules/**)",
      "Read(./dist/**)",
      "Read(./**/dist/**)",
      "Read(./build/**)",
      "Read(./**/build/**)",
      "Read(./coverage/**)",
      "Read(./**/coverage/**)"
    ]
  }
}