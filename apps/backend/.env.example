# Global env example. Copy app-specific values into each deployment environment.
NODE_ENV=development

# Domains
STUDENT_APP_URL=https://burroarab.uz
PARENT_APP_URL=https://parent.burroarab.uz
ADMIN_APP_URL=https://admin.burroarab.uz
API_URL=https://api.burroarab.uz

# Backend
PORT=3000
DATABASE_URL=postgres://burro:burro@localhost:5432/burro
BURRO_ATTEMPTS_STORE=in_memory
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
COOKIE_DOMAIN=.burroarab.uz

# Telegram
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_BOT_USERNAME=burroarab_bot
TELEGRAM_WEBHOOK_SECRET=change-me

# Uploads
UPLOADS_DIR=./uploads
PUBLIC_UPLOADS_URL=https://api.burroarab.uz/uploads

# Realtime
SOCKET_CORS_ORIGINS=https://burroarab.uz,https://parent.burroarab.uz,https://admin.burroarab.uz
