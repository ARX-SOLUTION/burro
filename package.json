{
  "name": "burro-fonetika-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:students": "pnpm --filter @burro/students dev",
    "dev:parents": "pnpm --filter @burro/parents dev",
    "dev:admin": "pnpm --filter @burro/adminpanel dev",
    "dev:backend": "pnpm --filter @burro/backend start:dev",
    "build": "pnpm -r build",
    "build:students": "pnpm --filter @burro/students build",
    "build:parents": "pnpm --filter @burro/parents build",
    "build:admin": "pnpm --filter @burro/adminpanel build",
    "build:backend": "pnpm --filter @burro/backend build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "latest"
  }
}
